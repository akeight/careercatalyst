datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ApplicationType {
  INTERNSHIP
  FELLOWSHIP
  EARLY_CAREER
}

enum Status {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum ContactType {
  RECRUITER
  REFERRAL
  CONNECTION
  MENTOR
  HIRING_MANAGER
  OTHER
}

enum RoleFamily {
  SOFTWARE_ENGINEERING
  FRONTEND_ENGINEERING
  MOBILE_DEVELOPMENT
  UX_UI_PRODUCT_DESIGN
  PRODUCT_MANAGEMENT
  OTHER
}

enum MobileSpecialization {
  IOS
  ANDROID
  CROSS_PLATFORM
  NOT_SPECIFIED
}

enum ResearchLevel {
  NONE
  SNAPSHOT
  INTERVIEW_BRIEF
}

enum ResearchRunMode {
  SNAPSHOT
  INTERVIEW_BRIEF
}

enum ResearchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum ResearchRunStage {
  REVIEWING_POSITION
  IDENTIFYING_COMPANY
  RESEARCHING_OFFICIAL_SOURCES
  FINDING_RECENT_DEVELOPMENTS
  BUILDING_ROLE_INSIGHTS
  CONNECTING_CANDIDATE_CONTEXT
  VALIDATING_CITATIONS
  SAVING_BRIEF
}

enum EvidenceTier {
  PRIMARY
  CREDIBLE_SECONDARY
  ANECDOTAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  applications Application[]
  notes        Note[]
  Company      Company[]
  contacts     Contact[]
  goals        Goal[]
  research     ApplicationResearch[]
  researchRuns ApplicationResearchRun[]
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Profile fields
  school       String?
  major        String?
  gradYear     Int?
  targetRole   String?

  // Professional links (optional)
  linkedInUrl  String?
  githubUrl    String?
  portfolioUrl String?

  // Resume (Vercel Blob)
  resumeUrl    String?
  resumeName   String?

  // Goals / onboarding
  weeklyGoal   Int       @default(5)
  onboardedAt  DateTime?
}

model Goal {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  title       String
  description String?
  completed   Boolean   @default(false)
  targetDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id           String        @id @default(cuid())
  name         String        @unique
  website      String?
  location     String?
  logoUrl      String?
  contacts     Contact[]
  applications Application[]
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Contact {
  id       String       @id @default(cuid())
  name     String
  email    String?
  phone    String?
  linkedIn String?
  role     String? // e.g. Recruiter, Referral, Manager
  type     ContactType?
  title    String? // their job title, e.g. "Engineering Manager"
  notes    String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  applications Application[] // if this contact is tied to specific applications

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  type      ApplicationType
  title     String
  location  String?
  status    Status          @default(SAVED)
  source    String?
  jobUrl    String?
  jobDescription String?
  roleFamily RoleFamily?
  mobileSpecialization MobileSpecialization?
  notes     String?
  appliedAt DateTime        @default(now())
  deadline  DateTime?
  favorite  Boolean         @default(false)

  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId String?

  noteRecords Note[]
  research    ApplicationResearch?
  researchRuns ApplicationResearchRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationResearch {
  id            String @id @default(cuid())
  applicationId String @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  highestLevel ResearchLevel @default(NONE)

  snapshotContent       Json?
  snapshotGeneratedAt   DateTime?
  snapshotSchemaVersion String?
  snapshotExcerpt       String?
  snapshotSourceCount   Int @default(0)
  snapshotStaleReason   String?

  briefContent       Json?
  briefGeneratedAt   DateTime?
  briefSchemaVersion String?
  promptVersion      String?
  briefExcerpt       String?
  briefSourceCount   Int @default(0)
  briefStaleReason   String?

  jobDescriptionHash String?
  candidateContext   String?
  companyDomain      String?
  companyResolvedName String?
  resolutionConfidence Float?

  sources ApplicationResearchSource[]
  runs    ApplicationResearchRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ApplicationResearchSource {
  id         String @id @default(cuid())
  researchId String
  research   ApplicationResearch @relation(fields: [researchId], references: [id], onDelete: Cascade)

  externalId       String
  url              String
  normalizedUrl    String
  title            String?
  publisher        String?
  sourceType       String
  evidenceTier     EvidenceTier
  publishedAt      DateTime?
  accessedAt       DateTime @default(now())
  excerpt          String?
  relevanceScore   Float?
  freshnessScore   Float?
  collectedAtLevel ResearchRunMode

  @@unique([researchId, normalizedUrl])
  @@index([researchId])
}

model ApplicationResearchRun {
  id            String @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  researchId    String
  research      ApplicationResearch @relation(fields: [researchId], references: [id], onDelete: Cascade)
  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode           ResearchRunMode
  status         ResearchRunStatus @default(PENDING)
  stage          ResearchRunStage?
  idempotencyKey String @unique
  errorCode      String?
  errorMessage   String?
  providerMeta   Json?
  usage          Json?
  attempt        Int @default(1)
  startedAt      DateTime?
  finishedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId, createdAt])
  @@index([userId, createdAt])
  @@index([researchId, createdAt])
}

model Note {
  id            String      @id @default(cuid())
  content       String
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
