datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  name           String?
  applications   Application[]
  createdAt      DateTime       @default(now())
}

model Application {
  id             String     @id @default(uuid())
  position       String
  company        String
  status         Status     @default(APPLIED)
  link           String?
  notes          String?
  deadline       DateTime?  // Optional: Only if the user sets one
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  userId         String
  user           User       @relation(fields: [userId], references: [id])
}

enum Status {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  SAVED
}

