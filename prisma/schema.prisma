datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ApplicationType {
  INTERNSHIP
  FELLOWSHIP
  EARLY_CAREER
}

enum Status {
  SAVED
  APPLIED
  INTERVIEW
  PENDING
  OFFER
  REJECTED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  applications Application[]
  notes        Note[]
  Company      Company[]
}

model Company {
  id           String        @id @default(cuid())
  name         String        @unique
  website      String?
  location     String?
  logoUrl      String?
  contacts     Contact[]
  applications Application[]
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Contact {
  id       String  @id @default(cuid())
  name     String
  email    String?
  phone    String?
  linkedIn String?
  role     String? // e.g. Recruiter, Referral, Manager

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  applications Application[] // if this contact is tied to specific applications
}

model Application {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  type      ApplicationType
  title     String
  location  String?
  status    Status          @default(SAVED)
  source    String?
  appliedAt DateTime        @default(now())
  deadline  DateTime?
  favorite  Boolean         @default(false)

  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?

  notes Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id            String      @id @default(cuid())
  content       String
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
